# Copy to docker/.env and adjust; docker/.env is gitignored.
# These defaults are for local development only.

# Broker credentials used by the rabbitmq container.
RABBITMQ_DEFAULT_USER=onclave
RABBITMQ_DEFAULT_PASS=onclave-dev

# AMQP URL the core service uses to reach the broker (inside the compose
# network the broker host is "rabbitmq"; vhost is "onclave").
ONCLAVE_AMQP_URL=amqp://onclave:onclave-dev@rabbitmq:5672/onclave
